---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---
<BaseLayout
  title="Blog — Tempo"
  description="Notes on building Tempo, the macOS event hub for your homelab."
>
  <header class="page-header">
    <nav class="page-nav">
      <a href="/">← Tempo</a>
    </nav>
    <h1>Blog</h1>
    <p class="lede">Notes from building Tempo.</p>
  </header>

  <main class="post-list">
    {posts.length === 0 && <p class="empty">No posts yet. Soon.</p>}
    {posts.map((post) => (
      <article class="post-row">
        <a class="post-link" href={`/blog/${post.id}/`}>
          <h2>{post.data.title}</h2>
          {post.data.description && <p class="post-desc">{post.data.description}</p>}
          <p class="post-meta">
            <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
            {post.data.tags && post.data.tags.length > 0 && (
              <>
                {" · "}
                {post.data.tags.join(", ")}
              </>
            )}
          </p>
        </a>
      </article>
    ))}
  </main>
</BaseLayout>

<style>
  .page-header {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 2rem 1.25rem 1.5rem;
  }
  .page-nav {
    font-size: 0.875rem;
    margin-bottom: 2rem;
  }
  .page-nav a { color: var(--text2); }
  .page-nav a:hover { color: var(--text); }

  .page-header h1 {
    font-size: 2rem;
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
  }
  .lede {
    color: var(--text2);
  }

  .post-list {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 1rem 1.25rem 4rem;
  }
  .empty {
    color: var(--text2);
    padding: 2rem 0;
  }

  .post-row {
    border-bottom: 1px solid var(--border);
  }
  .post-row:first-child {
    border-top: 1px solid var(--border);
  }

  .post-link {
    display: block;
    padding: 1.5rem 0;
    color: inherit;
    text-decoration: none;
  }
  .post-link:hover {
    text-decoration: none;
  }
  .post-link:hover h2 {
    color: var(--blue);
  }

  .post-row h2 {
    font-size: 1.25rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
    transition: color 120ms ease;
  }
  .post-desc {
    color: var(--text2);
    margin-bottom: 0.4rem;
  }
  .post-meta {
    color: var(--text3);
    font-size: 0.85rem;
  }
</style>
