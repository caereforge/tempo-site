---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) tags.add(tag);
  }
  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => (p.data.tags ?? []).includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---
<BaseLayout
  title={`${tag} — Tempo blog`}
  description={`Posts tagged "${tag}" on the Tempo blog.`}
>
  <header class="page-header">
    <nav class="page-nav">
      <a href="/blog/">← Blog</a>
    </nav>
    <h1>Tag: {tag}</h1>
    <p class="lede">{posts.length} post{posts.length === 1 ? "" : "s"}.</p>
  </header>

  <main class="post-list">
    {posts.map((post) => (
      <article class="post-row">
        <a class="post-link" href={`/blog/${post.id}/`}>
          <h2>{post.data.title}</h2>
          {post.data.description && <p class="post-desc">{post.data.description}</p>}
          <p class="post-meta">
            <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
            {post.data.tags && post.data.tags.length > 0 && (
              <>
                {" · "}
                {post.data.tags.join(", ")}
              </>
            )}
          </p>
        </a>
      </article>
    ))}
  </main>
</BaseLayout>

<style>
  .page-header {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 2rem 1.25rem 1.5rem;
  }
  .page-nav {
    font-size: 0.875rem;
    margin-bottom: 2rem;
  }
  .page-nav a { color: var(--text2); }
  .page-nav a:hover { color: var(--text); }

  .page-header h1 {
    font-size: 2rem;
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
  }
  .lede { color: var(--text2); }

  .post-list {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 1rem 1.25rem 4rem;
  }
  .post-row { border-bottom: 1px solid var(--border); }
  .post-row:first-child { border-top: 1px solid var(--border); }
  .post-link {
    display: block;
    padding: 1.5rem 0;
    color: inherit;
    text-decoration: none;
  }
  .post-link:hover h2 { color: var(--blue); }
  .post-row h2 {
    font-size: 1.25rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
    transition: color 120ms ease;
  }
  .post-desc { color: var(--text2); margin-bottom: 0.4rem; }
  .post-meta { color: var(--text3); font-size: 0.85rem; }
</style>
